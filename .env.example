PORT=3000
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=45000
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36
PLAYWRIGHT_EXECUTABLE_PATH=
SCRAPER_PROXY_PROTOCOL=http
SCRAPER_PROXY_SERVER=
SCRAPER_PROXY_USERNAME=
SCRAPER_PROXY_PASSWORD=
SCRAPER_PROXY_FILE=
SCRAPER_PROXY_INDEX=0
SCRAPER_SESSION_DIR=.playwright-tiktok-session
SCRAPER_BROWSER_CHANNEL=
SCRAPER_LOCALE=en-US
SCRAPER_TIMEZONE_ID=UTC
SCRAPER_LOGIN_USE_PROXY=false
YT_DLP_PATH=
YT_DLP_PROFILE_LIMIT=120
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
LIBRARY_STORAGE_MODE=local
LIBRARY_CLOUD_PROVIDER=s3-compatible
LIBRARY_CLOUD_PUBLIC_BASE_URL=
LIBRARY_CLOUD_BUCKET=
LIBRARY_CLOUD_REGION=auto
LIBRARY_CLOUD_ENDPOINT=
LIBRARY_CLOUD_ACCESS_KEY_ID=
LIBRARY_CLOUD_SECRET_ACCESS_KEY=
LIBRARY_CLOUD_FORCE_PATH_STYLE=false
LIBRARY_KEEP_LOCAL_COPY=true
PUBLICATION_WORKER_BATCH_SIZE=5
PUBLICATION_WORKER_PER_ACCOUNT_LIMIT=1
DISCOVERY_WORKER_SEED_LIMIT=5
DISCOVERY_WORKER_INTERVAL_MINUTES=30
# Optional local wrapper path for yt-dlp on Windows:
# YT_DLP_PATH=yt-dlp.cmd
